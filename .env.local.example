# ─────────────────────────────────────────────────────────────
# DebtFlow Admin — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# ─────────────────────────────────────────────────────────────

# MongoDB Atlas — connection string
# Crie uma conta gratuita em https://cloud.mongodb.com
# Clique em "Connect" → "Drivers" e copie a URI
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/debtflow?retryWrites=true&w=majority

# Senha de acesso ao sistema (qualquer string segura)
ADMIN_PASSWORD=suasenhaforte123

# Segredo para assinar o cookie de sessão (string aleatória longa)
# Gere com: openssl rand -base64 32
SESSION_SECRET=coloque-uma-string-aleatoria-longa-aqui

# (Produção apenas) URL do seu site no Vercel
NEXTAUTH_URL=https://seu-projeto.vercel.app

# Token para proteger o endpoint do Cron Job (crie qualquer string)
CRON_SECRET=outro-segredo-para-o-cron
